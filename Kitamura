<style>
  :root {
    --brand-primary: #003562;
    --brand-black: #000000;
    --brand-text: #333333;
    --brand-bg: #ffffff;
    --brand-border: #e2ddd8;
    --brand-muted: #767676;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    font-family: 'Urbanist', 'Hiragino Kaku Gothic ProN', 'メイリオ', Meiryo, sans-serif;
    color: var(--brand-text);
    background: var(--brand-bg);
    -webkit-font-smoothing: antialiased;
  }

  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }

  /* Header */
  .top-bar {
    background: var(--brand-primary);
    color: #fff;
    font-size: 11px;
    text-align: center;
    padding: 6px 10px;
    letter-spacing: 0.05em;
  }

  header.site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 32px;
    border-bottom: 1px solid var(--brand-border);
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 50;
  }

  .logo-wrap { display: flex; align-items: center; gap: 32px; }
  .logo-wrap img { height: 22px; }

  .main-nav { display: flex; gap: 24px; font-size: 13px; letter-spacing: 0.03em; }
  .main-nav a { padding: 6px 0; border-bottom: 2px solid transparent; }
  .main-nav a:hover { border-bottom-color: var(--brand-primary); }

  .header-icons { display: flex; gap: 18px; align-items: center; }
  .header-icons img { height: 18px; width: 18px; opacity: 0.75; }

  /* Breadcrumb */
  .breadcrumb {
    max-width: 1180px;
    margin: 0 auto;
    padding: 14px 32px 0;
    font-size: 12px;
    color: var(--brand-muted);
  }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb span { margin: 0 6px; }

  /* Product layout */
  .product-wrap {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 48px;
    padding: 24px 32px 60px;
  }

  .gallery { position: sticky; top: 90px; align-self: start; }
  .gallery-main {
    border: 1px solid var(--brand-border);
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #f7f5f3;
    margin-bottom: 10px;
  }
  .gallery-main img { width: 100%; height: 100%; object-fit: cover; }

  .gallery-thumbs {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 8px;
  }
  .gallery-thumbs img {
    aspect-ratio: 3/4;
    object-fit: cover;
    border: 1px solid var(--brand-border);
    cursor: pointer;
    background: #f7f5f3;
  }
  .gallery-thumbs img:hover { border-color: var(--brand-primary); }

  /* Product info */
  .product-info { padding-top: 4px; }
  .breadcrumb-mobile { display: none; }

  .product-title {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 6px;
    letter-spacing: 0.01em;
  }
  .product-sku {
    font-size: 12px;
    color: var(--brand-muted);
    margin-bottom: 14px;
  }
  .product-price {
    font-size: 20px;
    font-weight: 600;
    color: #333;
    margin-bottom: 22px;
  }

  .selector-block { margin-bottom: 20px; }
  .selector-label {
    font-size: 12px;
    color: var(--brand-muted);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }
  .swatch-row { display: flex; gap: 8px; }
  .swatch {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 2px solid var(--brand-border);
    background: #c9c9c9;
    cursor: pointer;
  }
  .swatch.active { border-color: var(--brand-primary); }

  .size-row { display: flex; gap: 8px; }
  .size-btn {
    min-width: 56px;
    padding: 10px 14px;
    border: 1px solid var(--brand-border);
    text-align: center;
    font-size: 13px;
    cursor: pointer;
    background: #fff;
  }
  .size-btn.active { border-color: var(--brand-primary); background: var(--brand-primary); color: #fff; }

  .gift-note {
    font-size: 12px;
    color: var(--brand-muted);
    margin-bottom: 18px;
  }

  .cta-row { display: flex; gap: 10px; margin-bottom: 6px; }
  .btn-cart {
    flex: 1;
    background: var(--brand-primary);
    color: #fff;
    border: none;
    padding: 15px 20px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    text-align: center;
  }
  .btn-cart:hover { background: #002744; }
  .btn-wishlist {
    width: 52px;
    border: 1px solid var(--brand-border);
    background: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }
  .order-note {
    font-size: 11px;
    color: var(--brand-muted);
    margin-bottom: 28px;
  }

  /* Firework module boxes */
  .fw-module-box {
    border: 1.5px solid var(--brand-border);
    border-radius: 8px;
    overflow: hidden;
    background: #ffffff;
    padding: 16px;
    margin-bottom: 16px;
  }
  .fw-module-label {
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--brand-muted);
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .perks-block {
    border-top: 1px solid var(--brand-border);
    border-bottom: 1px solid var(--brand-border);
    padding: 16px 0;
    margin-bottom: 24px;
    font-size: 12px;
    color: var(--brand-muted);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .perks-block div { display: flex; gap: 8px; align-items: center; }

  /* Tabs */
  .tabs-section {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px 60px;
  }
  .tab-headers {
    display: flex;
    gap: 32px;
    border-bottom: 1px solid var(--brand-border);
    overflow-x: auto;
    margin-bottom: 28px;
  }
  .tab-header {
    padding: 12px 4px;
    font-size: 14px;
    white-space: nowrap;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    color: var(--brand-muted);
  }
  .tab-header.active { color: var(--brand-primary); border-bottom-color: var(--brand-primary); font-weight: 600; }
  .tab-content { display: none; font-size: 13px; line-height: 1.9; color: #444; max-width: 760px; }
  .tab-content.active { display: block; }
  .spec-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .spec-table th, .spec-table td { text-align: left; padding: 8px 12px 8px 0; border-bottom: 1px solid var(--brand-border); }
  .spec-table th { width: 140px; color: var(--brand-muted); font-weight: 500; }

  /* Related */
  .related-section {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 32px 70px;
  }
  .related-title { font-size: 16px; font-weight: 600; margin-bottom: 20px; }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .related-card img {
    aspect-ratio: 3/4;
    object-fit: cover;
    background: #f7f5f3;
    margin-bottom: 10px;
  }
  .related-card .r-title { font-size: 13px; margin-bottom: 4px; }
  .related-card .r-price { font-size: 13px; font-weight: 600; }
  .related-card .r-price .strike { text-decoration: line-through; color: var(--brand-muted); font-weight: 400; margin-right: 6px; }

  footer {
    background: #f5f3f1;
    border-top: 1px solid var(--brand-border);
    padding: 40px 32px;
    font-size: 12px;
    color: var(--brand-muted);
    text-align: center;
  }

  @media (max-width: 900px) {
    header.site-header { padding: 12px 16px; }
    .main-nav { display: none; }
    .product-wrap { grid-template-columns: 1fr; padding: 16px 16px 40px; gap: 24px; }
    .gallery { position: static; }
    .breadcrumb { padding: 10px 16px 0; }
    .tabs-section, .related-section { padding-left: 16px; padding-right: 16px; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
    .tab-headers { gap: 20px; }
  }
</style>
</head>
